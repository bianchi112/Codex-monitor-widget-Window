<Window x:Class="CodexMonitorWidget.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:CodexMonitorWidget.Controls"
        Title="Codex Monitor"
        Icon="Assets/app-icon.ico"
        Width="320"
        Height="300"
        MinWidth="180"
        MinHeight="140"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        SizeChanged="OnWindowSizeChanged"
        Closing="OnWindowClosing">
    <Border Background="{StaticResource PanelBackgroundBrush}"
            BorderBrush="{StaticResource BorderBrushLight}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="8">
        <DockPanel LastChildFill="True">

            <!-- 드래그 가능한 상단 영역 (헤더 + 감시 상태) -->
            <Border DockPanel.Dock="Top"
                    MinHeight="72"
                    Padding="8,6,8,10"
                    Margin="0,0,0,4"
                    Background="Transparent"
                    Cursor="SizeAll"
                    MouseLeftButtonDown="OnDragWindow">
                <StackPanel>
                    <Grid>
                        <StackPanel Margin="0,0,36,0">
                            <TextBlock x:Name="TitleText"
                                       Text="Codex Monitor"
                                       FontWeight="SemiBold"
                                       FontSize="16"
                                       Foreground="White" />
                            <TextBlock Text="{Binding StatusMessage}"
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <Button x:Name="RefreshButton"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Width="28"
                                Height="28"
                                Content="↻"
                                ToolTip="새로고침"
                                Click="OnRefreshClick"
                                Visibility="Collapsed"
                                Background="Transparent"
                                BorderThickness="0"
                                Foreground="White"
                                Cursor="Hand" />
                    </Grid>

                    <Grid x:Name="WatchingPanel"
                          Visibility="Collapsed"
                          Margin="0,10,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="WatchIndicator" Width="8" Height="8" Fill="LimeGreen" Margin="0,0,6,0" />
                            <TextBlock x:Name="WatchStatusText" Text="자동 감시 중" FontSize="12" Foreground="White" />
                        </StackPanel>
                        <TextBlock x:Name="LastUpdatedText"
                                   HorizontalAlignment="Right"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </Grid>
                </StackPanel>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="RootPanel" Margin="8,0,8,8">

                    <!-- Permission state -->
                    <StackPanel x:Name="PermissionPanel" Visibility="Collapsed">
                        <TextBlock x:Name="PermissionIntro"
                                   Text="Codex 사용량을 보려면 `.codex` 폴더 접근 권한이 필요합니다."
                                   TextWrapping="Wrap"
                                   Foreground="White"
                                   Margin="0,0,0,8" />

                        <Border Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="예상 경로" FontSize="11" FontWeight="SemiBold" Foreground="White" />
                                <TextBlock x:Name="ExpectedCodexPathText"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0" />
                                <TextBlock x:Name="ExpectedSessionsPathText"
                                           FontFamily="Consolas"
                                           FontSize="11"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock x:Name="FolderStatusIcon" Text="⚠" Foreground="Orange" Margin="0,0,6,0" />
                            <TextBlock x:Name="FolderStatusText"
                                       FontSize="11"
                                       Foreground="{StaticResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <Button Content="~/.codex 선택하기"
                                Click="OnSelectFolderClick"
                                Padding="12,8"
                                Margin="0,0,0,6" />
                        <Button x:Name="OpenExplorerButton"
                                Content="탐색기에서 .codex 열기"
                                Click="OnOpenExplorerClick"
                                Padding="12,8"
                                Margin="0,0,0,6" />
                        <TextBlock x:Name="AccessErrorText"
                                   FontSize="11"
                                   Foreground="#FFFF6B6B"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <!-- Usage content -->
                    <StackPanel x:Name="UsagePanel" Visibility="Collapsed">
                        <TextBlock x:Name="TokenSectionTitle"
                                   Text="토큰 사용량"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,0,0,8"
                                   Visibility="Collapsed" />

                        <Border Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel x:Name="LastTurnPanel">
                                <TextBlock Text="방금 입력"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <TextBlock x:Name="LastUserPreviewText"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,0,0,6" />
                                <UniformGrid x:Name="LastTurnMetricsGrid" Columns="2" Rows="4" />
                                <StackPanel x:Name="BreakdownPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Separator Margin="0,0,0,6" Background="#33FFFFFF" />
                                    <TextBlock Text="입력 구성"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource SecondaryTextBrush}"
                                               Margin="0,0,0,4" />
                                    <UniformGrid x:Name="BreakdownExactGrid" Columns="2" Rows="1" Margin="0,0,0,4" />
                                    <TextBlock Text="항목별 구성 (추정)"
                                               FontSize="11"
                                               Foreground="#66FFFFFF"
                                               Margin="0,0,0,4" />
                                    <StackPanel x:Name="BreakdownComponentsPanel" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="10"
                                Margin="0,0,0,8">
                            <StackPanel>
                                <TextBlock Text="세션 누적"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SecondaryTextBrush}"
                                           Margin="0,0,0,4" />
                                <UniformGrid x:Name="SessionMetricsGrid" Columns="2" Rows="2" />
                            </StackPanel>
                        </Border>

                        <TextBlock x:Name="PlanTypeText"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   Margin="0,0,0,8" />

                        <controls:UsageGaugeControl x:Name="FiveHourGauge"
                                                    Title="5시간"
                                                    Margin="0,0,0,8" />
                        <controls:UsageGaugeControl x:Name="WeeklyGauge"
                                                    Title="주간"
                                                    Margin="0,0,0,8" />
                    </StackPanel>

                    <!-- Empty state -->
                    <StackPanel x:Name="EmptyPanel" Visibility="Collapsed">
                        <TextBlock Text="표시할 Codex 사용량이 없습니다."
                                   Foreground="White"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6" />
                        <TextBlock x:Name="EmptyPathText"
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6" />
                        <TextBlock Text="Codex를 사용하면 자동으로 갱신됩니다."
                                   FontSize="11"
                                   Foreground="{StaticResource SecondaryTextBrush}" />
                    </StackPanel>

                    <!-- Always on top -->
                    <CheckBox x:Name="AlwaysOnTopCheckBox"
                              Content="항상 위"
                              Foreground="White"
                              Margin="0,8,0,0"
                              Visibility="Collapsed"
                              Checked="OnAlwaysOnTopChanged"
                              Unchecked="OnAlwaysOnTopChanged" />
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>
