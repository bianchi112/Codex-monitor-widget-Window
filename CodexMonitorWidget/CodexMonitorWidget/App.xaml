<Application x:Class="CodexMonitorWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CodexMonitorWidget.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/ModernScrollBar.xaml" />
            </ResourceDictionary.MergedDictionaries>

        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <conv:CompactFontSizeConverter x:Key="CompactFontSizeConverter" />
        <conv:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <conv:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter" />

        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#CC1E1E1E" />
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="#99FFFFFF" />
        <SolidColorBrush x:Key="BorderBrushLight" Color="#1FFFFFFF" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
